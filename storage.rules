rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Imagens do construtor de e-mail de cada usuário.
    // Leitura pública (o cliente de e-mail precisa carregar a imagem sem login).
    // Escrita só o dono, só imagem, até 10 MB.
    match /users/{uid}/emailAssets/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Nega o resto por padrão.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
