rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Imagens do construtor de e-mail de cada usuário.
    // Leitura pública (o cliente de e-mail precisa carregar a imagem sem login).
    // Escrita só o dono, só imagem, até 1 MB (o app já comprime pra <1 MB antes de enviar).
    match /users/{uid}/emailAssets/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 1 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Áudios de Ligação IA (templates de voz gravados/enviados pelo cliente).
    // Leitura pública (a Telnyx precisa buscar o mp3/wav pela URL pra tocar na ligação).
    // Escrita só o dono, só áudio, até 10 MB.
    match /users/{uid}/callAudios/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Mídias dos Atendentes IA (imagens/áudios que a IA manda no WhatsApp).
    // Leitura pública (o n8n/WhatsApp busca a mídia pela URL). Escrita só o dono, imagem/áudio, até 10 MB.
    match /users/{uid}/atendenteAssets/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('(image|audio)/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Nega o resto por padrão.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
